<?xml version="1.0" encoding="UTF-8"?>

<!--
Local spring modifications.  This file is never altered by WaveMaker software,
and is an ideal location for end-users to put any code they need.
-->
<beans xmlns="http://www.springframework.org/schema/beans"
		xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
		xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!--
        Post-authentication success handler that promotes the LoginService token
        (received from /api/login) to a SERVER_ONLY scoped attribute on WMAuthentication.
        WaveMaker auto-discovers all WMAuthenticationSuccessHandler beans and invokes them
        after every successful login.
    -->
    <bean id="loginServiceTokenSuccessHandler"
          class="com.wavemaker.when_to_work.security.LoginServiceTokenSuccessHandler"/>

    <!--
        Overrides the platform's appDefaultRestRuntimeConfig (defined in project-rest-runtime-config.xml)
        to inject the SecurityTokenRequestProcessor into the HTTP request processor chain.
        All 13 REST services reference appDefaultRestRuntimeConfig, so this override ensures
        the Bearer token Authorization header is applied globally to every outgoing REST API call.

        This definition is a full replacement of the platform default and therefore preserves
        all original processors to avoid regressions:

        Request processors (in order):
          1. PassDefaultHeadersRequestProcessor  - forwards standard inbound headers (incl. X-Requested-With)
          2. HttpRequestCookieProcessor          - forwards inbound cookies
          3. SecurityTokenRequestProcessor       - injects Authorization: Bearer <loginServiceToken>

        Response processors (in order):
          1. HttpResponseCookieProcessor         - handles Set-Cookie from upstream responses
          2. PrefixHttpResponseHeadersResponseProcessor - prefixes upstream response headers with X-WM-
    -->
    <bean id="appDefaultRestRuntimeConfig"
          class="com.wavemaker.runtime.rest.processor.RestRuntimeConfig">
        <property name="httpRequestProcessorList">
            <list>
                <bean class="com.wavemaker.runtime.rest.processor.request.PassDefaultHeadersRequestProcessor">
                    <property name="enabled" value="true"/>
                    <property name="defaultHeaders">
                        <list>
                            <value>User-Agent</value>
                            <value>Content-Type</value>
                            <value>Accept</value>
                            <value>Accept-Charset</value>
                            <value>Accept-Language</value>
                            <value>X-Requested-With</value>
                        </list>
                    </property>
                </bean>
                <bean class="com.wavemaker.runtime.rest.processor.request.HttpRequestCookieProcessor">
                    <property name="enabled" value="true"/>
                </bean>
                <bean class="com.wavemaker.when_to_work.rest.SecurityTokenRequestProcessor">
                    <property name="enabled" value="true"/>
                </bean>
            </list>
        </property>
        <property name="httpResponseProcessorList">
            <list>
                <bean class="com.wavemaker.runtime.rest.processor.response.HttpResponseCookieProcessor">
                    <property name="enabled" value="true"/>
                    <property name="persistenceStrategy" value="NONE"/>
                </bean>
                <bean class="com.wavemaker.runtime.rest.processor.response.PrefixHttpResponseHeadersResponseProcessor">
                    <property name="enabled" value="true"/>
                    <property name="headerPrefix" value="X-WM-"/>
                    <property name="excludeList">
                        <list>
                            <value>Content-Disposition</value>
                            <value>Content-Type</value>
                            <value>Set-Cookie</value>
                        </list>
                    </property>
                </bean>
            </list>
        </property>
    </bean>

</beans>
