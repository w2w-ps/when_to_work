<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 https://maven.apache.org/xsd/settings-1.0.0.xsd">
    <localRepository/>
    <interactiveMode/>
    <offline/>
    <pluginGroups/>
    <servers>
    </servers>
    <mirrors>
    </mirrors>
    <proxies/>
    <profiles>
        <profile>
            <id>wavemaker-internal</id>
            <activation>
                <activeByDefault>true</activeByDefault>
            </activation>
            <repositories>
                <repository>
                    <id>wavemaker-internal</id>
                    <name>wavemaker-nexus</name>
            <url>https://repository.wavemaker.com/repository/wavemaker-maven-repo/</url>
                    <releases>
                        <enabled>true</enabled>
                        <checksumPolicy>ignore</checksumPolicy>
                    </releases>
                    <snapshots>
                        <enabled>true</enabled>
                    </snapshots>
        </repository>
            </repositories>
            <pluginRepositories>
                <pluginRepository>
                    <id>wavemaker-internal</id>
                    <name>wavemaker-nexus</name>
                    <url>https://repository.wavemaker.com/repository/wavemaker-maven-repo/</url>
                    <releases>
                        <enabled>true</enabled>
                        <checksumPolicy>ignore</checksumPolicy>
                    </releases>
                    <snapshots>
                        <enabled>true</enabled>
                    </snapshots>
                </pluginRepository>
            </pluginRepositories>
        </profile>
    </profiles>
    <activeProfiles/>
</settings>
