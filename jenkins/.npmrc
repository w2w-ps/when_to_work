# Default registry (public npm)
registry=https://registry.npmjs.org/
# Correct scope for wavemaker-ai
@wavemaker-ai:registry=https://repository.wavemaker.com/repository/wavemaker-npm-repo/
# Wavemaker scoped packages use private repo
@wavemaker:registry=https://repository.wavemaker.com/repository/wavemaker-npm-repo/

# Improve reliability
strict-ssl=true
fetch-retries=3
fetch-retry-factor=2
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000

# Reduce noise in CI logs
loglevel=warn
